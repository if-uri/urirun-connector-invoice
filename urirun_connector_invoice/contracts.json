      "inp": { "path": "?str", "text": "?str", "use_llm": "?bool", "model": "?str" },
      "out": {
        "connector": "const:invoice", "kind": "const:invoice", "live": "bool",
        "path": "str", "method": "str", "fields": "obj"
      },
      "errors": ["precondition-unmet", "degraded-backend"],
      "examples": [
        {
          "payload": { "text": "FAKTURA VAT nr FV 1/2026\nNIP 7781422455\nRazem 123.00 PLN" },
          "result": {
            "ok": true, "connector": "invoice", "kind": "invoice", "live": false,
            "path": "", "method": "regex", "fields": { "nip": "7781422455", "gross": 123.0 }
          }
        }
      ]
    },
